{
    "name": "@mrrflow/tracker",
    "version": "1.0.0",
    "description": "Privacy-first analytics tracker for SaaS companies",
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "browser": "dist/tracker.min.js",
    "unpkg": "dist/tracker.min.js",
    "types": "dist/index.d.ts",
    "files": [
      "dist",
      "README.md",
      "LICENSE",
      "esbuild.config.js"
    ],
    "scripts": {
      "build": "npm run clean && npm run build:lib",
      "build:lib": "tsc && rollup -c rollup.config.mjs",
      "clean": "rimraf dist",
      "test": "jest",
      "test:watch": "jest --watch",
      "lint": "eslint src --ext .ts",
      "format": "prettier --write src/**/*.ts",
      "size": "bundlesize",
      "prepublishOnly": "npm run build && npm test",
      "dev": "rollup -c rollup.config.mjs --watch"
    },
    "keywords": [
      "analytics",
      "tracking",
      "privacy",
      "gdpr",
      "saas",
      "metrics",
      "revenue"
    ],
    "author": "MRRFlow Team",
    "license": "MIT",
    "repository": {
      "type": "git",
      "url": "https://github.com/mrrflow/tracker"
    },
    "homepage": "https://mrrflow.io",
    "bugs": {
      "url": "https://github.com/mrrflow/tracker/issues"
    },
    "devDependencies": {
      "@rollup/plugin-node-resolve": "^15.0.0",
      "@rollup/plugin-replace": "^5.0.0",
      "@rollup/plugin-terser": "^0.4.0",
      "@rollup/plugin-typescript": "^11.0.0",
      "@types/jest": "^29.0.0",
      "@typescript-eslint/eslint-plugin": "^6.0.0",
      "@typescript-eslint/parser": "^6.0.0",
      "bundlesize": "^0.18.0",
      "esbuild": "^0.19.0",
      "eslint": "^8.0.0",
      "jest": "^29.0.0",
      "prettier": "^3.0.0",
      "rimraf": "^5.0.0",
      "rollup": "^4.0.0",
      "ts-jest": "^29.0.0",
      "tslib": "^2.6.0",
      "typescript": "^5.0.0"
    },
    "bundlesize": [
      {
        "path": "./dist/tracker.min.js",
        "maxSize": "2kb",
        "compression": "gzip"
      }
    ],
    "jest": {
      "preset": "ts-jest",
      "testEnvironment": "jsdom",
      "setupFilesAfterEnv": ["<rootDir>/src/__tests__/setup.ts"]
    },
    "eslintConfig": {
      "extends": [
        "@typescript-eslint/recommended"
      ],
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "warn",
        "@typescript-eslint/no-unused-vars": "error"
      }
    },
    "prettier": {
      "semi": true,
      "trailingComma": "es5",
      "singleQuote": true,
      "printWidth": 80,
      "tabWidth": 2
    }
  }